{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "outDir": "./dist/renderer",
    "rootDir": "./src",
    "noEmit": true
  },
  "include": ["src/renderer/**/*.ts", "src/shared/**/*.ts"]
}
