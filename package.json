{
  "name": "rtl-fixer-v2",
  "version": "0.2.0",
  "private": true,
  "description": "Floating Grammarly-style overlay for Arabic text on Windows",
  "main": "dist/main/main.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"main,renderer,electron\" -c \"yellow.bold,cyan.bold,magenta.bold\" \"pnpm dev:main\" \"pnpm dev:renderer\" \"wait-on tcp:5173 && wait-on dist/main/main.js && electron .\"",
    "dev:main": "tsc -p tsconfig.main.json --watch --preserveWatchOutput",
    "dev:renderer": "vite",
    "build": "pnpm clean && pnpm build:main && pnpm build:preload && pnpm build:renderer && pnpm build:exe",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build:exe": "electron-builder --config electron-builder.yml",
    "clean": "rimraf dist coverage .vite",
    "lint": "eslint . && prettier --check \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "lint:fix": "eslint . --fix && prettier --write \"**/*.{ts,tsx,js,jsx,json,md,html,css}\"",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:e2e": "playwright test",
    "icons": "powershell -ExecutionPolicy Bypass -File scripts/gen-icons.ps1"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.13.0",
    "playwright": "^1.48.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
